AMOY_RPC_URL="https://polygon-amoy.g.alchemy.com/v2/I7-3CRJgWy1yz4xpkdKI1"

# Your Wallet Private Key (EXPORT FROM METAMASK)
# IMPORTANT: Use a separate 'development' wallet, never your main wallet!
PRIVATE_KEY="fa85a13d74729ecf485687c1e973f7eb53f3eda7098fedcc48f0205fcc8de98a"

# (Optional) EtherScan API Key for contract verification
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_KEY"
